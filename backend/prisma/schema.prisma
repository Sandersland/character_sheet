generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// level and proficiencyBonus are intentionally NOT columns here — they're
// always derived from experiencePoints at read time (see
// src/lib/experience.ts). Don't add them back as persisted fields.
//
// race/class/background are NOT columns here either — they're modeled as
// per-character selection rows (CharacterRace/CharacterClassEntry/
// CharacterBackground below) that each link to a baseline catalog entry via
// a nullable FK but carry their own display name. This lets a sheet's
// race/class/background name drift from (or fully replace) the catalog
// entry without breaking the link used for mechanical derivation, and lets
// class be one-to-many for future multiclass support.
//
// inventory follows the same pattern via InventoryItem below (and is NOT a
// Json column here) rather than the sparse-overlay shape race/class/
// background use: each row *snapshots* a catalog Item's stats at add-time
// instead of just a name, since equipment commonly needs every field edited
// (Club -> "Club +1" with bonus damage) and a snapshot needs no merge logic
// to read or write. itemId is kept only as a provenance pointer.
model Character {
  id          String  @id @default(uuid())
  name        String
  alignment   String
  portraitUrl String?

  // Owning user. Legitimately persisted (NOT derived) — ownership is identity
  // state, not a function of any other column, so it's exempt from the
  // derive-don't-persist rule that excludes level/proficiencyBonus/race/etc.
  // onDelete: Cascade — deleting a user removes their characters. "Only the
  // owner may read/write" is enforced (#101) via requireAuth (app.ts) +
  // assertCharacterAccess (lib/auth/access.ts), the single sharing seam (#116).
  ownerId     String
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Optional shared-campaign link (#246). SetNull so deleting a campaign leaves
  // the character intact (just unassigned).
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  experiencePoints Int @default(0)

  initiativeBonus Int
  speed           Int

  hitPoints     Json
  hitDice       Json
  abilityScores Json

  savingThrowProficiencies String[]
  skills                   Json
  // Array of { name, source } — tool proficiencies granted at character
  // creation by background / class / race. Never trimmed on level-down.
  // Level-gated choices (e.g. Student of War) live in resources Json instead.
  toolProficiencies        Json

  currency     Json
  spellcasting Json?
  // Mutable resource state: { used: Record<key,count>, maneuversKnown: ManeuverEntry[] }.
  // Only `used` counts and known lists persist; totals/die-size/recharge are
  // derived at read time by deriveResources() in src/lib/srd.ts.
  resources    Json?
  // Mutable conditions state: { active: ConditionEntry[], exhaustion: number }.
  // `active` holds the standard 5e status conditions (prone, poisoned, etc.) by
  // boolean presence; `exhaustion` is a single 0–6 level (special case). The
  // canonical condition rules data lives in src/lib/srd.ts (CONDITIONS).
  conditions   Json?
  // Mutable active-effects state: { buffs: ActiveBuff[] }. Cast-granted stat
  // modifiers (e.g. a concentration buff spell), each tagged with the casting
  // entry id so they clear when that concentration ends. Normalized on read;
  // mutate via the cast path, never PATCH.
  activeEffects Json?

  raceSelection       CharacterRace?
  backgroundSelection CharacterBackground?
  classEntries        CharacterClassEntry[]
  inventoryItems      InventoryItem[]
  events              CharacterEvent[]
  sessionParticipants SessionParticipant[]
  journalEntries      JournalEntry[]
  // Back-relation to the PC CampaignEntity auto-created on attach (#248).
  campaignLink        CampaignCharacterLink?
  // Per-campaign play preferences (#537) — one row per campaign this character
  // has ever set prefs in; the current campaign's row is surfaced on read.
  campaignPreferences CampaignCharacterPreference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([campaignId])
}

// --- Identity & ownership ---------------------------------------------------
// Authentication user model. Wired to Character via ownerId so every sheet has
// an owner; per-owner read/write is enforced (#101) by requireAuth +
// assertCharacterAccess. Sign-in is OAuth/session via the AuthAccount /
// AuthSession tables (#100).

model User {
  id       String  @id @default(uuid())
  // Nullable + unique: an emailless bootstrap user can exist (single-player
  // today); OAuth/credential users added in #100 will carry an email.
  email    String? @unique
  name     String?
  imageUrl String?

  accounts   AuthAccount[]
  sessions   AuthSession[]
  characters Character[]

  // Shared campaigns (#246): ones this user owns + memberships in any campaign.
  ownedCampaigns      Campaign[]           @relation("CampaignOwner")
  campaignMemberships CampaignMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Shared campaigns (#246) ------------------------------------------------
// A Campaign is a shared backbone several characters (and their owners) join.
// Plain-REST domain (NOT the transaction/audit pattern): membership is identity
// state, access is gated by CampaignMembership via assertCampaignMembership.

model Campaign {
  id         String   @id @default(uuid())
  name       String
  ownerId    String
  owner      User     @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  // Opaque random join code (same crypto as session tokens). Unique so /join
  // resolves a campaign by code.
  inviteCode String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members    CampaignMembership[]
  characters Character[]
  // Shared campaign wiki: NPCs/locations/factions/etc. tagged in notes (#248).
  entities   CampaignEntity[]
  // DM-authored campaign items, each auto-linked to an ITEM entity (#380).
  items      CampaignItem[]
  // Non-destructive "revealed to be" identity links between entities (#387).
  entityMerges CampaignEntityMerge[]
  sessions   Session[]
  // Per-character play preferences scoped to this campaign (#537).
  characterPreferences CampaignCharacterPreference[]
}

enum CampaignRole {
  OWNER
  PLAYER
}

model CampaignMembership {
  id         String       @id @default(uuid())
  campaignId String
  campaign   Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       CampaignRole @default(PLAYER)
  joinedAt   DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([campaignId, userId])
}

// --- Campaign entity registry & @-tagging (#248) ----------------------------
// A shared campaign wiki: a polymorphic registry of the people/places/things a
// table references. Fully polymorphic (one `type` discriminator, NO per-type FK
// columns) so a new entity kind is an enum value, not a table. Notes @-tag an
// entity via an @[<uuid>] token in the body; JournalEntryRef materializes each
// tag as a backlink. A PC entity is auto-created + linked when a character
// attaches to the campaign (CampaignCharacterLink).

enum EntityType {
  NPC
  LOCATION
  FACTION
  ITEM
  PC
  OTHER
}

// DM-controlled reveal state (#379): HIDDEN entities are invisible to non-owner
// members (list/detail/backlinks/mentions); the owner always sees all. New rows
// default REVEALED so auto-created PC entities and the pre-#379 backfill are open.
enum EntityVisibility {
  HIDDEN
  REVEALED
}

model CampaignEntity {
  id         String           @id @default(uuid())
  campaignId String
  campaign   Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       EntityType
  name       String
  aliases    String[]         @default([])
  notes      String?
  visibility EntityVisibility @default(REVEALED)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  refs          JournalEntryRef[]
  characterLink CampaignCharacterLink?
  // Back-relation to the DM-authored item this entity fronts (#380).
  itemLink      CampaignItemLink?
  // Identity-merge back-relations (#387): the (single) merge where this entity
  // is the old identity, and the merges where it is the surviving true identity.
  mergedInto    CampaignEntityMerge?  @relation("MergedIdentity")
  survivorOf    CampaignEntityMerge[] @relation("SurvivorIdentity")

  @@index([campaignId, type])
}

// Materialized backlink: one row per (entry, entity) tag. Derived from the
// @[<uuid>] tokens in the entry body on journal write; cascades from both sides.
model JournalEntryRef {
  id       String         @id @default(uuid())
  entryId  String
  entry    JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entityId String
  entity   CampaignEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entryId, entityId])
  @@index([entityId])
}

// Links a character to its auto-created PC entity (1:1 both ways).
model CampaignCharacterLink {
  id               String         @id @default(uuid())
  campaignEntityId String         @unique
  campaignEntity   CampaignEntity @relation(fields: [campaignEntityId], references: [id], onDelete: Cascade)
  characterId      String         @unique
  character        Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

// --- Entity identity merges (#387) ------------------------------------------
// A non-destructive "revealed to be" link: `mergedEntity` (the old identity,
// e.g. Jenkins) is the same being as `survivorEntity` (the true identity, e.g.
// Vecna). Neither row is destroyed and no journal ref is rewritten — a chip that
// tagged the old id keeps resolving to the old id. PREPARED is the DM's secret
// prep (scrubbed from every non-owner payload, like a HIDDEN entity #379);
// EXECUTED is the public reveal. Chains resolve transitively (Jenkins→Vecna→
// Whispered One). Cascades from either entity so the record dies with either side.
enum MergeStatus {
  PREPARED
  EXECUTED
}

model CampaignEntityMerge {
  id               String         @id @default(uuid())
  campaignId       String
  campaign         Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // The old identity; at most one merge per merged entity.
  mergedEntityId   String         @unique
  mergedEntity     CampaignEntity @relation("MergedIdentity", fields: [mergedEntityId], references: [id], onDelete: Cascade)
  // The surviving true identity (may itself be merged further up the chain).
  survivorEntityId String
  survivorEntity   CampaignEntity @relation("SurvivorIdentity", fields: [survivorEntityId], references: [id], onDelete: Cascade)
  status           MergeStatus    @default(PREPARED)
  note             String?
  preparedAt       DateTime       @default(now())
  executedAt       DateTime?

  @@index([campaignId])
  @@index([survivorEntityId])
}

// --- DM-authored campaign items (#380) --------------------------------------
// A DM-authored magic item / loot entry that lives in a campaign (NOT on any
// character sheet). Mirrors the catalog Item shape — per-category mechanical
// fields live on the optional 1:1 *Detail tables below, not as nullable
// columns — plus DM-only fields (rarity, attunement, isUnique, dmNotes). On
// create it auto-registers a HIDDEN ITEM CampaignEntity via CampaignItemLink
// (same pattern as CampaignCharacterLink), so it is @-mentionable and gets
// reveal/hide + backlinks for free from the #248/#379 machinery. dmNotes is
// DM-private and is scrubbed from every player-facing payload in routes/items.ts.
model CampaignItem {
  id                 String       @id @default(uuid())
  campaignId         String
  campaign           Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  category           ItemCategory
  rarity             ItemRarity?
  // Paper-doll slot for wearable gear (#565); same meaning as Item.slot.
  slot               EquipSlot?
  requiresAttunement Boolean      @default(false)
  // Attunement prerequisite (#545) — null kind = attunable by anyone. Snapshotted
  // onto InventoryItem on award so the check runs against the frozen copy.
  attunementPrereqKind  AttunementPrereqKind?
  attunementPrereqValue String?
  isUnique           Boolean      @default(false)
  weight             Float?
  cost               Json? // {cp,sp,gp,pp} — same shape as Item.cost
  // DM-private prep notes — never serialized into a player-facing response.
  dmNotes            String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  weaponDetail     CampaignItemWeaponDetail?
  armorDetail      CampaignItemArmorDetail?
  consumableDetail CampaignItemConsumableDetail?
  capabilities     CampaignItemCapability[]
  link             CampaignItemLink?
  // Awarded snapshots on player sheets (#381) — holder derivation reads these.
  awards           InventoryItem[]           @relation("CampaignItemAwards")

  @@index([campaignId])
}

// Same shape as ItemWeaponDetail, owned by CampaignItem.
model CampaignItemWeaponDetail {
  id             String       @id @default(uuid())
  campaignItemId String       @unique
  campaignItem   CampaignItem @relation(fields: [campaignItemId], references: [id], onDelete: Cascade)

  damageDiceCount Int
  damageDiceFaces Int
  damageModifier  Int    @default(0)
  damageType      String

  versatileDiceCount Int?
  versatileDiceFaces Int?

  finesse     Boolean @default(false)
  light       Boolean @default(false)
  heavy       Boolean @default(false)
  twoHanded   Boolean @default(false)
  reach       Boolean @default(false)
  thrown      Boolean @default(false)
  ammunition  Boolean @default(false)
  rangeNormal Int?
  rangeLong   Int?

  weaponClass WeaponClass?
  weaponRange WeaponRange?
}

// Same shape as ItemArmorDetail, owned by CampaignItem.
model CampaignItemArmorDetail {
  id             String       @id @default(uuid())
  campaignItemId String       @unique
  campaignItem   CampaignItem @relation(fields: [campaignItemId], references: [id], onDelete: Cascade)

  armorCategory       ArmorCategory
  baseArmorClass      Int
  dexModifierApplies  Boolean       @default(false)
  dexModifierMax      Int?
  stealthDisadvantage Boolean       @default(false)
  strengthRequirement Int?
}

// Same shape as ItemConsumableDetail, owned by CampaignItem.
model CampaignItemConsumableDetail {
  id             String       @id @default(uuid())
  campaignItemId String       @unique
  campaignItem   CampaignItem @relation(fields: [campaignItemId], references: [id], onDelete: Cascade)

  effectDiceCount   Int?
  effectDiceFaces   Int?
  effectModifier    Int?
  effectDescription String?

  // Limited-use charges (#121). null = stackable; non-null = charged.
  maxUses       Int?
  usesRemaining Int?
}

// Typed 1:N capability side-table (#545). Kind-discriminated with flat columns;
// readCapability in lib/capabilities.ts is the adapter. Only passiveBonus is
// read today. Snapshotted to InventoryCapability on award (same column set).
model CampaignItemCapability {
  id             String       @id @default(uuid())
  campaignItemId String
  campaignItem   CampaignItem @relation(fields: [campaignItemId], references: [id], onDelete: Cascade)

  kind        CapabilityKind
  description String?

  // passiveBonus payload
  target    CapabilityTarget?
  op        CapabilityOp?
  value     Int?
  // Specific skill/ability/save key when target is skill|abilityScore|save.
  targetKey String?
  condition String?

  // Dice-valued bonus (round-trips now; consumed in the damage roll at #526C).
  valueDiceCount  Int?
  valueDiceFaces  Int?
  valueDamageType String?

  // castSpell payload (#528): the item grants a spell cast from the item itself.
  spellId           String? // catalog Spell.id provenance
  spellName         String? // snapshot for display without a catalog join
  spellLevel        Int?
  castLevel         Int? // slot level the item casts the spell at
  castResource      CapabilityCastResource?
  castUses          Int? // uses per recharge period (null = 1)
  castConcentration Boolean?
  dcMode            CapabilityCastStatMode?
  dcValue           Int?
  attackMode        CapabilityCastStatMode?
  attackValue       Int?

  // activatedEffect payload (#543). The inline while-active self-buff reuses the
  // target/op/value columns above; these add the activation + recharge model.
  activation      ActivationType?
  activatedDuration ActivatedDuration?
  resourceKind    ItemResourceKind?
  resourcePeriod  ItemResourcePeriod?
  resourceCharges Int?
  // Free-text wall-clock duration ("10 minutes") surfaced as reminder text.
  durationText    String?

  // grant payload (#529): resistance/immunity/conditionImmunity/advantage/proficiency.
  grantType       String?
  grantOn         String?
  grantValueKind  String?
  grantValue      String?
  cantBeSurprised Boolean @default(false)

  // charges payload (#555): the item's shared charge pool — at most ONE charges
  // row per item (authoring-enforced). All-null recharge dice = full refill on
  // the trigger; dawn/dusk approximate to a long rest (see ItemResourcePeriod).
  maxCharges        Int?
  rechargeDiceCount Int?
  rechargeDiceFaces Int?
  rechargeBonus     Int?
  rechargeTrigger   ItemResourcePeriod?
  // Cost (in pool charges) paid by a castSpell/activatedEffect capability whose
  // resource is `charges` (null = 1). Lives on the SPENDING capability's row.
  chargeCost        Int?

  @@index([campaignItemId])
}

// Links a CampaignItem to its auto-created ITEM entity (1:1 both ways), same
// pattern as CampaignCharacterLink. DELETE cleanup rule (routes/items.ts):
// deleting the item deletes BOTH this link (cascade) AND the fronting entity
// (explicit, in the same transaction) — the entity has no life without its item.
model CampaignItemLink {
  id               String         @id @default(uuid())
  campaignEntityId String         @unique
  campaignEntity   CampaignEntity @relation(fields: [campaignEntityId], references: [id], onDelete: Cascade)
  campaignItemId   String         @unique
  campaignItem     CampaignItem   @relation(fields: [campaignItemId], references: [id], onDelete: Cascade)
}

// --- Campaign-scoped character preferences (#537) ---------------------------
// A player's per-campaign play settings for one of their characters (e.g. share
// sheet with the DM, auto-roll friendly healing). Scoped to (campaign,
// character) so the same character can carry different settings across
// campaigns. Owner-only writes via assertCharacterAccess; both FKs cascade so a
// deleted campaign or character removes its preference rows.
model CampaignCharacterPreference {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  // Let the DM read this character's sheet (lands with #116 sharing).
  shareWithDm         Boolean @default(false)
  // Auto-roll healing when this character targets a friendly (lands with #462).
  autoFriendlyHealing Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, characterId])
  @@index([characterId])
}

// One row per linked sign-in method (OAuth provider account or, later, a
// local-credentials record). Tokens live HERE, never on User, so a user can
// hold several providers and rotating tokens never touches the identity row.
// passwordHash is future-credentials-only and stays null for OAuth accounts.
model AuthAccount {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  // Null for OAuth; set only when local username/password credentials are
  // added in a future iteration.
  passwordHash      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

// Server-side session. `id` is the opaque cookie token itself (NO default) —
// it's generated by the auth layer and stored verbatim, so a leaked token
// can't be guessed from a sequential/uuid pattern we control here.
model AuthSession {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- Reference catalog -----------------------------------------------------
// Baseline lists offered in the character-creation form. These are seeded
// from a small SRD subset (see prisma/seed.ts) and are NOT referenced
// directly by Character — only through the nullable FKs on the selection
// models below, so deleting/renaming a catalog row never breaks an existing
// character sheet.

model Race {
  id                String   @id @default(uuid())
  name              String   @unique
  speed             Int
  toolProficiencies String[] @default([])

  selections CharacterRace[]
}

model CharacterClass {
  id               String   @id @default(uuid())
  name             String   @unique
  hitDie           String // e.g. "d8"
  savingThrows     String[] // ability names, e.g. ["strength", "constitution"]
  skillChoiceCount Int
  skillChoices     String[] // eligible skill names to choose from
  isSpellcaster    Boolean  @default(false)
  // Character level at which this class first grants a subclass choice.
  // Cleric/Sorcerer/Warlock = 1, Wizard/Druid = 2, most others = 3.
  subclassLevel    Int      @default(3)
  // Tool proficiency grants — fixed tools the class always grants.
  toolProficiencies  String[] @default([])
  // Tool proficiency choices — player picks toolChoiceCount from this list.
  toolChoices        String[] @default([])
  toolChoiceCount    Int      @default(0)

  entries    CharacterClassEntry[]
  subclasses Subclass[]
}

// Subclass catalog — Pattern A (like Race/CharacterClass). Each row is a
// named subclass belonging to one CharacterClass. The nullable FK on
// CharacterClassEntry.subclassId points here; `onDelete: SetNull` keeps
// existing entries intact if a catalog subclass is ever removed. Homebrew
// subclasses are represented by a null subclassId with a drifting name string,
// same as homebrew races/classes/backgrounds.
model Subclass {
  id          String         @id @default(uuid())
  classId     String
  class       CharacterClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  name        String
  description String

  selections CharacterClassEntry[]

  @@unique([classId, name])
}

model Background {
  id                 String   @id @default(uuid())
  name               String   @unique
  skillProficiencies String[]
  toolProficiencies  String[] @default([])

  selections CharacterBackground[]
}

// --- Per-character selections -----------------------------------------------
// Each links a Character to a catalog row (optionally — null means
// homebrew, no baseline) and carries its own `name`, which defaults to the
// catalog entry's name at creation but is free to drift independently.

model CharacterRace {
  id          String    @id @default(uuid())
  characterId String    @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  raceId      String?
  race        Race?     @relation(fields: [raceId], references: [id], onDelete: SetNull)
  name        String
}

model CharacterBackground {
  id           String      @id @default(uuid())
  characterId  String      @unique
  character    Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  backgroundId String?
  background   Background? @relation(fields: [backgroundId], references: [id], onDelete: SetNull)
  name         String
}

// One-to-many (not @unique on characterId): a character can hold several
// class entries, which is what multiclassing needs. v1 always creates
// exactly one entry per character (position 0).
model CharacterClassEntry {
  id          String          @id @default(uuid())
  characterId String
  character   Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  classId     String?
  class       CharacterClass? @relation(fields: [classId], references: [id], onDelete: SetNull)
  name        String
  level       Int             @default(1)
  // Drifting subclass display name — free to diverge from the catalog row's
  // name (same pattern as the `name` field coexisting with `classId`). Set on
  // creation or via POST …/class/transactions. Null = no subclass chosen yet.
  subclass    String?
  // Nullable FK to the Subclass catalog. Null means homebrew or no subclass.
  subclassId  String?
  subclassRef Subclass?       @relation(fields: [subclassId], references: [id], onDelete: SetNull)
  position    Int             @default(0)
}

enum ItemCategory {
  weapon
  armor
  consumable
  gear
}

// The six 5e magic-item rarity tiers (DMG p. 135). Rules data + gp values live
// in lib/srd.ts (ITEM_RARITIES); this is only the persisted column domain.
enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  VERY_RARE
  LEGENDARY
  ARTIFACT
}

enum ArmorCategory {
  light
  medium
  heavy
  shield
}

// Paper-doll equip slots (#565). A worn/wielded item occupies exactly one slot
// per row; RING has capacity 2, every other slot capacity 1. A two-handed weapon
// sits in MAIN_HAND and locks OFF_HAND (never a second row). Weapons/body armor
// derive their eligible slots from detail data; gear declares its slot via the
// nullable Item.slot / InventoryItem.slot column (null = bag-only, not wearable).
enum EquipSlot {
  MAIN_HAND
  OFF_HAND
  BODY
  HEAD
  NECK
  CLOAK
  HANDS
  WRISTS
  BELT
  FEET
  RING
}

// Weapon proficiency group — used by the starting-equipment package resolver
// to filter open picks like "any martial weapon". Nullable on both detail
// tables: homebrew weapons (custom acquire) may omit classification without
// breaking anything; open-pick validation simply skips weapons whose value
// is null.
enum WeaponClass {
  simple
  martial
}

// Whether a weapon is wielded in melee or at range — combined with
// WeaponClass for finer open-pick filters like "any martial melee weapon"
// (Barbarian). Nullable for the same reasons as WeaponClass above.
enum WeaponRange {
  melee
  ranged
}

// Lifecycle of a play session: active while in progress, ended when the
// player wraps up and optionally awards XP.
enum SessionStatus {
  active
  ended
}

// Item-capability discriminator (#545). Reserves the full A–E menu; only
// passiveBonus is implemented this slice — the rest are forward-declared so the
// side-table column set + adapter don't churn when they land.
enum CapabilityKind {
  passiveBonus
  castSpell
  charges
  grant
  activatedEffect
}

// Recharge period of a castSpell capability's item resource (#528). atWill is
// unlimited (no use tracking). perDay dawn/dusk approximate to a long rest.
// charges (#555) spends the item's shared charge pool (chargeCost per cast)
// instead of a per-capability counter.
enum CapabilityCastResource {
  perRestShort
  perRestLong
  perDayDawn
  perDayDusk
  atWill
  charges
}

// Whether a castSpell DC / attack bonus is a fixed item value or resolves to the
// wielder's own spell save DC / spell attack (#528).
enum CapabilityCastStatMode {
  fixed
  wielder
}

// Which derived stat a passiveBonus capability targets. Only scalar targets are
// summed into the modifier channel today; ac (#383) + dice→damage (#526C) defer.
enum CapabilityTarget {
  ac
  attack
  damage
  save
  skill
  abilityScore
  spellAttack
  spellDc
  initiative
  speed
  maxHp
}

// How a passiveBonus applies: add to the target's modifier channel, or set an
// absolute floor/override (setTo not yet consumed in derivation this slice).
enum CapabilityOp {
  add
  setTo
}

// How an activatedEffect capability (#543) is triggered in play. commandWord is
// a no-action verbal toggle; the rest mirror 5e's action economy.
enum ActivationType {
  action
  bonus
  reaction
  commandWord
}

// How long an activatedEffect's seeded self-buff rides the holder (#543). Maps to
// the ActiveBuff duration axis: whileActive = manual toggle-off, untilRest = a rest.
enum ActivatedDuration {
  whileActive
  untilRest
}

// The recharge model for an activatedEffect's uses (#543). perRest/perDay bound
// the uses per period; atWill is unlimited (never spends). charges (#555) spends
// the item's shared charge pool (chargeCost per activation).
enum ItemResourceKind {
  perRest
  perDay
  atWill
  charges
}

// The period an ItemResourceKind recharges over (#543). short|long pair with
// perRest; dawn|dusk with perDay (approximated to a long rest on reset).
enum ItemResourcePeriod {
  short
  long
  dawn
  dusk
}

// Attunement prerequisite category (5e "requires attunement by a …"). value
// carries the specific class/species/alignment; spellcaster needs no value.
enum AttunementPrereqKind {
  class
  spellcaster
  species
  alignment
}

// Spell schools per the 5e SRD. Mirrors frontend/src/types/character.ts
// SpellSchool — the two must stay in sync.
enum SpellSchool {
  abjuration
  conjuration
  divination
  enchantment
  evocation
  illusion
  necromancy
  transmutation
}

// Action catalog — seeded with universal 5e combat actions (Dodge, Dash, etc.)
// and class-specific abilities (Rage, Second Wind, Flurry of Blows, etc.).
// Holds DISPLAY + GATING data only. Executable mechanics are hardcoded in
// backend/src/lib/actions.ts (ACTION_EFFECT_FN keyed by `key`) — the same
// split as CLASS_RESOURCE_FN vs. the DerivedResource descriptions here.
// Adding a new action = append a row to seed.ts + add the effect fn in
// actions.ts. No migration needed for new actions; only new columns need one.
model Action {
  id          String     @id @default(uuid())
  key         String     @unique  // stable machine key, e.g. "rage" | "dodge"
  name        String               // display label
  description String

  // Which economy slot this action consumes on the character's turn.
  cost        ActionCost

  // Gating — universal actions are available to everyone; class/subclass/level
  // actions are gated by the character's class entry.
  universal   Boolean    @default(false)
  grantClass  String?    // lowercase class name, e.g. "fighter"
  grantSubclass String?  // lowercase subclass name (optional, for subclass-only abilities)
  grantLevel  Int?       // minimum character level for this action to appear

  // Optional scalar resource-spend hint — used by deriveActions to determine
  // `enabled` (e.g. Rage costs 1 "rage"; Flurry costs 2 "ki"). No program,
  // just two columns that let deriveActions check remaining > amount.
  resourceKey    String? // matches DerivedResource.key, e.g. "rage"
  resourceAmount Int?    // units required; null means no resource check needed
}

enum ActionCost {
  action
  bonusAction
  reaction
  free
  special
}

// Generic granted-ability catalog — source discriminates ("discipline" for Four
// Elements, "shadowArts" for Way of Shadow, "maneuver" for Battle Master).
// Embeds min level, save ability, EffectSpec + AbilityCost. Provenance pointer in
// DisciplineEntry.disciplineId / ManeuverEntry.maneuverId.
model GrantedAbility {
  id          String  @id @default(uuid())
  name        String  @unique
  source      String  @default("discipline")
  description String
  minLevel    Int     @default(3) // minimum monk level to learn
  alwaysKnown Boolean @default(false) // Elemental Attunement — free, uncapped

  // Battle Master maneuver placement/action metadata (source "maneuver" only).
  // placement routes the session UI: attackRoll | damageRoll | reaction | effect
  // | attackOption. actionSlot is the economy slot consumed (bonusAction/reaction),
  // null when none. selfTempHp = Rally (die + Cha mod as self temp HP).
  placement   String?
  actionSlot  String?
  selfTempHp  Boolean @default(false)

  // Embedded AbilityCost (F2) — ki-pool spend. kind "none" = free.
  costKind    String? // "none" | "pool"
  costPoolKey String? // e.g. "ki"
  costBase    Int?    // base ki cost
  costPerStep Int?    // additional ki per scaling step

  // Embedded EffectSpec (F1) — same flat columns as Spell. saveAbility doubles
  // as the discipline's DC save ability.
  effectKind         String?
  effectDiceCount    Int?
  effectDiceFaces    Int?
  effectDieSource    String? // e.g. "superiorityDice" — resolves faces from DerivedClassInfo, supersedes effectDiceFaces
  effectModifier     Int?
  damageType         String?
  attackType         String?
  saveAbility        String?
  saveEffect         String?
  upcastDicePerLevel Int?
  cantripScaling     Boolean @default(false)

  // Passive-modifier (buff) effect: applies a flat modifier to a skill/stat
  // target while the granting concentration holds. null = not a buff.
  buffTarget         String?
  buffModifier       Int?
}

// Feat catalog — seeded from a curated SRD subset. Provenance pointer in
// AdvancementEntry.featId (nullable so custom feats have no catalog row).
// abilityOptions/abilityIncrease drive the half-feat ability bump (e.g.
// Resilient: +1 to one chosen ability). Empty abilityOptions = not a half-feat.
model Feat {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String
  prerequisite    String?
  abilityOptions  String[] @default([]) // abilities the player may raise by abilityIncrease
  abilityIncrease Int      @default(0)  // usually 1 for half-feats
  improvements    Json     @default("[]") // FeatImprovement[]: { target, amount, perLevel? }
}

// Baseline spell catalog — same catalog-table role as Item above. Seeded from
// a curated SRD subset (prisma/seed.ts). Never referenced by a direct FK on
// Character; provenance lives in the per-character spellcasting JSON blob's
// SpellEntry.spellId field, nullable so homebrew spells have no catalog row.
// All per-spell mechanical data lives here rather than on a *Detail table —
// spells are flat (school/level/effect/scaling) rather than category-
// polymorphic like items, so no detail table split is needed.
model Spell {
  id          String      @id @default(uuid())
  name        String      @unique
  level       Int         // 0 = cantrip
  school      SpellSchool
  castingTime String
  range       String
  duration    String
  description String
  concentration Boolean   @default(false)
  ritual      Boolean     @default(false)
  classes     String[]    // lowercase class names the spell appears on, e.g. ["wizard","sorcerer"]

  // Spell components for spellbook display + future component checks.
  // { verbal: bool, somatic: bool, material: bool, materialDescription?: string }
  components  Json?

  // Structured effect data for auto-rolling at cast time (RollSpec-shaped,
  // mirrors ItemWeaponDetail / ItemConsumableDetail). null = utility spell.
  effectKind         String?  // "damage" | "heal" — null means utility (no roll)
  effectDiceCount    Int?
  effectDiceFaces    Int?
  effectModifier     Int?     // flat bonus added after dice (e.g. +3 in "3d4+3")
  damageType         String?  // "fire" / "radiant" / etc. — for damage spells
  attackType         String?  // "attack" | "save" | null
  saveAbility        String?  // ability the target saves with, e.g. "dexterity"
  // For save-based damage spells: "half" = half damage on a successful save
  // (Fireball), "none" = no damage on save. null for attack spells / utility.
  saveEffect         String?
  // Extra effect dice added per slot level cast above the base level (null =
  // spell has no upcast scaling — Fireball adds 1d6 per upcast level).
  upcastDicePerLevel Int?
  // Cantrip damage scales with character level (5/11/17 thresholds) per 5e rules.
  cantripScaling     Boolean  @default(false)
}

// Baseline equipment catalog, same role as Race/CharacterClass above: seeded
// from a small SRD subset (prisma/seed.ts) and never referenced directly by
// Character — only through InventoryItem.itemId, which is nullable, so
// editing/removing a catalog row never breaks an existing character's
// inventory. Mechanical fields specific to one category (damage dice, AC,
// an effect roll) live on the optional *Detail tables below rather than as
// nullable columns here — see those models' comments for why.
model Item {
  id          String       @id @default(uuid())
  name        String       @unique
  category    ItemCategory
  weight      Float?
  cost        Json? // {cp,sp,gp,pp} — sell/buy default, player can override
  description String?
  // Paper-doll slot for gear (#565). null = bag-only (not wearable). Weapons
  // and body armor derive their slot from detail data, so this is only set for
  // wearable gear (rings, cloaks, amulets, boots, etc.).
  slot        EquipSlot?

  weaponDetail     ItemWeaponDetail?
  armorDetail      ItemArmorDetail?
  consumableDetail ItemConsumableDetail?

  inventoryItems InventoryItem[]
  packContents   PackContent[]
}

// Optional 1:1 with Item, present only when category = weapon. The FK lives
// here (joins up to Item) rather than Item holding a column that points at
// this table — keeps Item itself free of per-category columns no matter how
// many detail tables exist. Dice fields are decomposed (count/faces/
// modifier) to match frontend/src/lib/dice.ts's RollSpec shape rather than
// a "1d6" string, so a future damage-roll feature reads these directly
// instead of parsing notation.
model ItemWeaponDetail {
  id     String @id @default(uuid())
  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  damageDiceCount Int
  damageDiceFaces Int
  damageModifier  Int    @default(0)
  damageType      String // e.g. "bludgeoning"

  // Versatile weapons' two-handed grip rolls a different die; null on both
  // means not versatile. Which grip is "currently" in use is deliberately
  // not persisted anywhere — a future roll UI offers both dice at roll time.
  versatileDiceCount Int?
  versatileDiceFaces Int?

  finesse     Boolean @default(false)
  light       Boolean @default(false)
  heavy       Boolean @default(false)
  twoHanded   Boolean @default(false)
  reach       Boolean @default(false)
  thrown      Boolean @default(false)
  ammunition  Boolean @default(false)
  rangeNormal Int?
  rangeLong   Int?

  // Proficiency group and melee/ranged classification — used by the
  // starting-equipment resolver to filter open picks. Nullable so existing
  // homebrew weapons and weapons added before this migration require no
  // backfill.
  weaponClass WeaponClass?
  weaponRange WeaponRange?
}

// Optional 1:1 with Item, present only when category = armor (shields
// included — a shield's baseArmorClass is its flat AC bonus rather than a
// base, same overload the 5e SRD itself uses).
model ItemArmorDetail {
  id     String @id @default(uuid())
  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  armorCategory       ArmorCategory
  baseArmorClass      Int
  dexModifierApplies  Boolean       @default(false)
  dexModifierMax      Int? // null = uncapped (light armor)
  stealthDisadvantage Boolean       @default(false)
  strengthRequirement Int?
}

// Optional 1:1 with Item, present only when category = consumable and the
// consumable actually has a roll (e.g. a potion's "2d4+2" healing) — a torch
// wouldn't have one. Same RollSpec-shaped dice fields as ItemWeaponDetail,
// for the same reason (a future "use consumable, roll its effect" feature).
model ItemConsumableDetail {
  id     String @id @default(uuid())
  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  effectDiceCount   Int?
  effectDiceFaces   Int?
  effectModifier    Int?
  effectDescription String? // e.g. "Restores hit points"

  // Limited-use charges (#121). null = stackable; non-null = charged.
  maxUses       Int?
  usesRemaining Int?
}

// Equipment packs — a named collection of items awarded as a bundle at
// character creation. The pack itself also exists as a regular catalog Item
// (category = gear) so it surfaces correctly in StartingEquipmentEditor;
// this table adds the expansion data (which items + how many).
// Seeded from the 5e Basic Rules baseline; custom packs can be added later.
model Pack {
  id          String        @id @default(uuid())
  name        String        @unique // matches the bundle catalogName, e.g. "Scholar's Pack"
  description String?
  contents    PackContent[]
}

// Join between Pack and the catalog Items it contains.
// quantity is the number of that item included in the pack.
model PackContent {
  id       String @id @default(uuid())
  packId   String
  pack     Pack   @relation(fields: [packId], references: [id], onDelete: Cascade)
  itemId   String
  item     Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantity Int    @default(1)

  @@unique([packId, itemId])
}

// Per-character inventory row. Unlike CharacterRace/CharacterBackground
// (which carry just a drifting `name`), this snapshots the full set of
// mechanical fields from the catalog Item at add-time — see the comment on
// Character above for why. itemId is nullable: null means homebrew (no
// catalog row at all), set means "started from this catalog item," and
// either way every field below (including the *Detail row, if any) is this
// row's own copy, free to diverge — e.g. a "Club +1" bumping its own
// InventoryWeaponDetail.damageModifier independent of the catalog Club.
model InventoryItem {
  id          String       @id @default(uuid())
  characterId String
  character   Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemId      String?
  item        Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)
  // Provenance of a DM-awarded campaign item (#381) — mirrors the itemId
  // provenance pattern above. Null for player-acquired rows; SetNull so
  // deleting the CampaignItem leaves the awarded snapshot intact.
  campaignItemId String?
  campaignItem   CampaignItem? @relation("CampaignItemAwards", fields: [campaignItemId], references: [id], onDelete: SetNull)
  name        String
  category    ItemCategory
  weight      Float?
  cost        Json?
  description String?
  quantity    Int          @default(1)
  // Paper-doll placement (#565). The SINGLE source of truth for "is this equipped":
  // the wire `equipped` field is DERIVED as (equippedSlot != null) in
  // serializeCharacter — there is no persisted `equipped` boolean. A two-handed
  // weapon occupies MAIN_HAND and locks OFF_HAND (never a second row).
  equippedSlot EquipSlot?
  // Snapshot of the source Item/CampaignItem.slot for wearable gear (#565).
  slot        EquipSlot?
  // Snapshot of the source CampaignItem.rarity for the Worn view (#565) — carried
  // alongside requiresAttunement below; display-only, no derivation reads it.
  rarity      ItemRarity?
  // Attunement state (#545) — persisted boolean; the 3-item cap is DERIVED
  // (counted), never stored. attune/unattune go through …/inventory/transactions.
  attuned     Boolean      @default(false)
  // Snapshot of the source CampaignItem's attunement metadata (#545). requiresAttunement
  // is captured at award time because the frozen copy outlives the mutable/deletable source;
  // prereqKind null = attunable by anyone (distinct from requiresAttunement false = not attunable).
  requiresAttunement    Boolean               @default(false)
  attunementPrereqKind  AttunementPrereqKind?
  attunementPrereqValue String?
  notes       String?
  position    Int          @default(0)
  // Uses spent on an activatedEffect capability since its last recharge (#543).
  // Reset by the matching rest; the seeded self-buff tracks the "active" state.
  activatedUsesSpent Int    @default(0)

  weaponDetail     InventoryWeaponDetail?
  armorDetail      InventoryArmorDetail?
  consumableDetail InventoryConsumableDetail?
  capabilities     InventoryCapability[]
}

// Snapshot twin of CampaignItemCapability, owned by InventoryItem (#545). Same
// column set — a straight field copy on award (snapshotCampaignItemDetail).
model InventoryCapability {
  id              String        @id @default(uuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  kind        CapabilityKind
  description String?

  target    CapabilityTarget?
  op        CapabilityOp?
  value     Int?
  targetKey String?
  condition String?

  valueDiceCount  Int?
  valueDiceFaces  Int?
  valueDamageType String?

  // castSpell payload (#528) — authored columns snapshotted 1:1 from the source.
  spellId           String?
  spellName         String?
  spellLevel        Int?
  castLevel         Int?
  castResource      CapabilityCastResource?
  castUses          Int?
  castConcentration Boolean?
  dcMode            CapabilityCastStatMode?
  dcValue           Int?
  attackMode        CapabilityCastStatMode?
  attackValue       Int?

  // activatedEffect payload (#543) — snapshot twin of CampaignItemCapability.
  activation      ActivationType?
  activatedDuration ActivatedDuration?
  resourceKind    ItemResourceKind?
  resourcePeriod  ItemResourcePeriod?
  resourceCharges Int?
  durationText    String?

  // grant payload (#529): resistance/immunity/conditionImmunity/advantage/proficiency.
  grantType       String?
  grantOn         String?
  grantValueKind  String?
  grantValue      String?
  cantBeSurprised Boolean @default(false)

  // charges payload (#555) — snapshot twin of CampaignItemCapability. On a
  // kind=charges row, `used` below is the POOL's spend counter (remaining is
  // derived as maxCharges − used, never stored).
  maxCharges        Int?
  rechargeDiceCount Int?
  rechargeDiceFaces Int?
  rechargeBonus     Int?
  rechargeTrigger   ItemResourcePeriod?
  chargeCost        Int?

  // Runtime use counter — inventory-only (not an authored field). Reset on the
  // matching rest by the HP rest handlers; never copied on award.
  used              Int     @default(0)

  @@index([inventoryItemId])
}

// Same shape as ItemWeaponDetail, owned by InventoryItem instead of Item.
model InventoryWeaponDetail {
  id              String        @id @default(uuid())
  inventoryItemId String        @unique
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  damageDiceCount Int
  damageDiceFaces Int
  damageModifier  Int    @default(0)
  damageType      String

  versatileDiceCount Int?
  versatileDiceFaces Int?

  finesse     Boolean @default(false)
  light       Boolean @default(false)
  heavy       Boolean @default(false)
  twoHanded   Boolean @default(false)
  reach       Boolean @default(false)
  thrown      Boolean @default(false)
  ammunition  Boolean @default(false)
  rangeNormal Int?
  rangeLong   Int?

  // Snapshot of ItemWeaponDetail.weaponClass/weaponRange — same nullable
  // reasoning as the catalog side.
  weaponClass WeaponClass?
  weaponRange WeaponRange?
}

// Same shape as ItemArmorDetail, owned by InventoryItem instead of Item.
model InventoryArmorDetail {
  id              String        @id @default(uuid())
  inventoryItemId String        @unique
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  armorCategory       ArmorCategory
  baseArmorClass      Int
  dexModifierApplies  Boolean       @default(false)
  dexModifierMax      Int?
  stealthDisadvantage Boolean       @default(false)
  strengthRequirement Int?
}

// Same shape as ItemConsumableDetail, owned by InventoryItem instead of Item.
model InventoryConsumableDetail {
  id              String        @id @default(uuid())
  inventoryItemId String        @unique
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  effectDiceCount   Int?
  effectDiceFaces   Int?
  effectModifier    Int?
  effectDescription String?

  // Limited-use charges (#121). null = stackable; non-null = charged.
  maxUses       Int?
  usesRemaining Int?
}

// ── Unified character activity log ──────────────────────────────────────────
//
// All meaningful state changes (inventory, HP, XP, currency, and future
// domains) are written here, in the same DB transaction as the state change
// itself. This is an append-only audit log — NOT event sourcing. The
// Character row stays the source of truth; these events sit beside it.
//
// Three patterns at work:
//  1. Single-Table Inheritance (category + type discriminators) — one table,
//     one ORDER BY createdAt query, no merging anywhere. Adding a new domain
//     = adding enum values, not new tables.
//  2. Polymorphic soft-reference (entityType + entityId, no FK) — points at
//     whatever row the event concerns (InventoryItem, etc.) without a hard FK
//     that breaks on deletion. Enables the per-item filter on the ledger view.
//  3. before/after JSON snapshots — "old value / new value" for field-level
//     audit; also the data needed for undo (Phase 4) without replaying
//     anything. CharacterEventField rows are derived from the diff at write time.
//
// Historical InventoryTransaction rows were migrated in on first deploy;
// the InventoryTransaction table and InventoryTxnType enum were dropped then.

enum CharacterEventCategory {
  inventory
  hitPoints
  experience
  currency
  spellcasting
  class        // subclass selection and future multiclass ops
  resources    // superiority dice, ki, rage, maneuvers, etc.
  advancement  // ability score improvements and feats
  session      // session lifecycle: started / ended
  combat       // combat lifecycle: started / ended / round advanced
  conditions   // status conditions (prone, poisoned, etc.) + exhaustion level
  effects      // active cast-granted stat modifiers (buffs)
  roll         // dice rolls logged from the session UI (attack/damage/check/save/initiative)
  // future: journal
}

enum CharacterEventType {
  // inventory (mirrors the former InventoryTxnType)
  acquired
  consumed
  sold
  bought
  removed
  // DM campaign-item award/revoke (#381)
  awarded
  revoked
  // hitPoints
  damage
  heal
  setTemp
  shortRest
  longRest
  levelUp
  levelDown
  deathSave
  stabilize
  // experience
  xpAward
  xpSet
  // currency
  currencyAdjust
  // spellcasting
  castSpell
  expendSlot
  restoreSlot
  learnSpell
  forgetSpell
  prepareSpell
  unprepareSpell
  concentrationDropped
  // class
  classAdded
  subclassChosen
  subclassRemoved
  fightingStyleChosen
  fightingStyleRemoved
  classLevelsReconciled
  // resources
  spendResource
  restoreResource
  learnManeuver
  forgetManeuver
  maneuversReconciled
  learnDiscipline
  forgetDiscipline
  swapDiscipline
  disciplinesReconciled
  castDiscipline
  castManeuver
  castShadowArt
  castChannelDivinity
  learnToolProficiency
  forgetToolProficiency
  toolProficienciesReconciled
  // advancement (ASI + feats)
  abilityScoreImprovement
  featTaken
  advancementRemoved
  advancementsReconciled
  // inventory (equip/unequip are logged so they appear on the timeline)
  equipped
  unequipped
  // inventory attunement (#545)
  attuned
  unattuned
  // inventory activated effects (#543)
  activated
  deactivated
  activatedRecharged
  // session lifecycle
  sessionStarted
  sessionEnded
  // combat lifecycle
  combatStarted
  combatEnded
  combatRoundAdvanced
  // conditions
  conditionApplied
  conditionRemoved
  exhaustionSet
  // effects (active buffs)
  buffApplied
  buffCleared
  // roll events (rolls logged from session UI — non-undoable)
  attackRoll
  damageRoll
  checkRoll
  saveRoll
  initiativeRoll
  // meta
  revert
}

model CharacterEvent {
  id          String                 @id @default(uuid())
  characterId String
  character   Character              @relation(fields: [characterId], references: [id], onDelete: Cascade)
  category    CharacterEventCategory
  type        CharacterEventType
  // Human-readable snapshot of the action, e.g. "Leveled up to 7 (+9 HP)" or
  // "Sold Shortsword ×1 (+7 gp)". Stored so the timeline renders correctly
  // even if op semantics change in a future version.
  summary     String
  // Polymorphic soft-reference — no FK, so the event survives deletion of the
  // referenced row. entityType = "InventoryItem", entityId = the row's id.
  entityType  String?
  entityId    String?
  // Full snapshot of the affected sub-state before and after the op.
  // Null for historical rows backfilled from InventoryTransaction (no data).
  // For undo: restoring `before` reverses any event that carries it.
  before      Json?
  after       Json?
  // Op-specific inputs that aren't derivable from before/after alone, e.g.
  // method/roll/conMod for levelUp, itemName/currencyDelta for inventory.
  // Also carries undo-reconstruction data the revert handler reads but that
  // must NOT be diffed: inventory delete ops stash a self-contained
  // `data.deletedItem` snapshot here so the deleted row can be rebuilt.
  data        Json?
  // Future-proofs multi-user "who performed this action" — single-player
  // today, so always "player".
  actor       String                 @default("player")
  // Set true when this event has been compensated via a `revert` meta-event.
  // The reverted row is never deleted — history is append-only.
  reverted    Boolean                @default(false)
  batchId     String?
  // Nullable FK to the play session during which this event occurred.
  // Null for events that happen outside a session (shopping between sessions,
  // level-ups on the reference sheet, etc.).
  sessionId   String?
  session     Session?               @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdAt   DateTime               @default(now())

  fields CharacterEventField[]

  @@index([characterId, createdAt])
  @@index([entityType, entityId])
  @@index([sessionId, createdAt])
}

// One shared play session per campaign sitting; participants join/leave it (#245).
// At most one `active` session per campaign (enforced in lib, not a DB partial-unique).
model Session {
  id          String        @id @default(uuid())
  campaignId  String
  campaign    Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  status      SessionStatus @default(active)
  startedAt   DateTime      @default(now())
  endedAt     DateTime?
  // Optional human-readable name for the session, e.g. "Session 4 — The Sunless Citadel".
  title       String?
  // Campaign recap aggregate computed at session-end (#245). Null while active.
  summary     Json?

  events         CharacterEvent[]
  journalEntries JournalEntry[]
  participants   SessionParticipant[]

  @@index([campaignId, status])
}

// One character's membership in a shared session, with their present-interval
// (joinedAt..leftAt) and per-participant summary computed at session-end (#245).
model SessionParticipant {
  id          String    @id @default(uuid())
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?
  summary     Json?

  @@unique([sessionId, characterId])
  @@index([sessionId])
}

// kind distinguishes the two capture surfaces sharing this table: full ENTRY
// rows (date/body form) vs. fast NOTE rows (one-line in-session capture, date
// defaults to today). EntryVisibility ships private-by-default; the CAMPAIGN
// share toggle is deferred but needs no schema change to enable later.
enum JournalEntryKind {
  NOTE
  ENTRY
}

enum EntryVisibility {
  PRIVATE
  CAMPAIGN
}

// Freeform campaign journal — purely user-authored notes with no mechanical
// effect, so (unlike inventory/HP/XP/spellcasting) it is NOT routed through
// the audit log / transaction pattern: plain REST CRUD writes directly here.
// Optionally tagged with the session it was written during (SetNull so a
// deleted session leaves the note intact). `date` is the in-world / real date
// the player assigns to the entry; `createdAt` is the system write time used
// for stable newest-first ordering. `loggedAt` is the capture timestamp shown
// on NOTE rows. `authorUserId` denormalizes the writing user so visibleEntries
// can filter private-by-default without a join.
model JournalEntry {
  id           String           @id @default(uuid())
  characterId  String
  character    Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  sessionId    String?
  session      Session?         @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  kind         JournalEntryKind @default(ENTRY)
  date         DateTime
  loggedAt     DateTime         @default(now())
  body         String
  visibility   EntryVisibility  @default(PRIVATE)
  authorUserId String
  createdAt    DateTime         @default(now())

  // Materialized @-tags pointing at CampaignEntity rows (#248).
  refs JournalEntryRef[]

  @@index([characterId, createdAt])
}

// Per-field diff rows derived from before/after at write time — the
// "field-level" layer of the "both layers" granularity choice. Each row
// records one changed leaf path (e.g. "hitPoints.max"), its old value, and
// its new value. Cascades with the parent event.
model CharacterEventField {
  id       String         @id @default(uuid())
  eventId  String
  event    CharacterEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  path     String         // e.g. "hitPoints.max", "currency.gp", "quantity"
  oldValue Json?
  newValue Json?
}
