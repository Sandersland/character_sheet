    "level": 5,
  },
  {
    "info": {
      "features": [
        {
          "description": "Choose a type of favored enemy (beasts, fey, humanoids of a specific type, etc.). You have advantage on Survival checks to track them and on Intelligence checks to recall information about them. You learn one language spoken by your favored enemy. Additional enemy at L6 and L14.",
          "level": 1,
          "name": "Favored Enemy",
          "source": "class",
        },
        {
          "description": "Choose a favored terrain type. When traveling in it: ignore difficult terrain, can't be surprised if alert, advantage on Initiative rolls, initiative even if surprised once per turn, move at normal pace while stealthing. Additional terrain at L6 and L10.",
          "level": 1,
          "name": "Natural Explorer",
          "source": "class",
        },
        {
          "description": "Choose: Archery (+2 ranged attack rolls), Defense (+1 AC in armor), Dueling (+2 melee damage with one weapon), or Two-Weapon Fighting (add ability modifier to off-hand damage).",
          "level": 2,
          "name": "Fighting Style",
          "source": "class",
        },
        {
          "description": "You cast spells using Wisdom. Half-caster progression (first slots at level 2, one level behind full casters). You prepare a number of ranger spells equal to half your ranger level + Wisdom modifier (minimum 1).",
          "level": 2,
          "name": "Spellcasting",
          "source": "class",
        },
        {
          "description": "Choose one: Colossus Slayer (once per turn, +1d8 damage to a wounded creature); Giant Killer (reaction attack when a Large+ creature misses you); or Horde Breaker (once per turn, attack a second creature adjacent to the first).",
          "level": 3,
          "name": "Hunter's Prey",
          "source": "subclass",
        },
        {
          "description": "Expend one spell slot to focus your awareness for 1 minute per slot level. You sense whether certain types of creatures are within 1 mile (or 6 miles in your favored terrain).",
          "level": 3,
          "name": "Primeval Awareness",
          "source": "class",
        },
        {
          "description": "You can attack twice whenever you take the Attack action on your turn.",
          "level": 5,
          "name": "Extra Attack",
          "source": "class",
        },
      ],
      "resources": [],
      "subclassChoices": [
        {
          "catalogSource": "huntersPrey",
          "count": 1,
          "key": "huntersPrey",
          "label": "Hunter's Prey",
        },
      ],
    },
    "level": 6,
  },
