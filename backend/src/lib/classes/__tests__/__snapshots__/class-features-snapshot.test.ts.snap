          "description": "Bond with a beast companion of CR 1/4 or lower. It acts on your turn (using your action to command it after the first round). It uses your proficiency bonus and gains bonus HP equal to four times your ranger level.",
          "level": 3,
          "name": "Ranger's Companion",
          "source": "subclass",
        },
        {
          "description": "You can attack twice whenever you take the Attack action on your turn.",
          "level": 5,
          "name": "Extra Attack",
          "source": "class",
        },
        {
          "description": "Use a bonus action to command your companion to Dash, Disengage, Dodge, or Help. Its attacks count as magical.",
          "level": 7,
          "name": "Exceptional Training",
          "source": "subclass",
        },
