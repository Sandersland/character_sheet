      "features": [
        {
          "description": "As a bonus action, give one creature within 60 ft a Bardic Inspiration die (d6, becoming d8 at L5, d10 at L10, d12 at L15). They add it to one ability check, attack roll, or saving throw within 10 minutes.",
          "level": 1,
          "name": "Bardic Inspiration",
          "source": "class",
        },
        {
          "description": "You cast spells using Charisma. Full-caster progression (same slot table as Cleric/Wizard). You know a set number of spells from the bard list.",
          "level": 1,
          "name": "Spellcasting",
          "source": "class",
        },
        {
          "description": "Add half your proficiency bonus (rounded down) to any ability check that doesn't already use your proficiency bonus.",
          "level": 2,
          "name": "Jack of All Trades",
          "source": "class",
        },
        {
          "description": "If you or any friendly creatures spend hit dice during a short rest and you perform, they regain extra HP: 1d6 (L2), d8 (L9), d10 (L13), d12 (L17).",
          "level": 2,
          "name": "Song of Rest",
          "source": "class",
        },
        {
          "description": "You gain proficiency with medium armor, shields, and martial weapons.",
          "level": 3,
          "name": "Bonus Proficiencies",
          "source": "subclass",
        },
        {
          "description": "A creature with a Bardic Inspiration die from you can also add it to a damage roll or use it as a reaction to add it to AC against one attack.",
          "level": 3,
          "name": "Combat Inspiration",
          "source": "subclass",
        },
        {
          "description": "Choose two of your skill proficiencies (or one skill + Thieves' Tools). Your proficiency bonus is doubled for those skills. Two more skills at level 10.",
          "level": 3,
          "name": "Expertise",
          "source": "class",
        },
        {
          "description": "You regain all of your expended Bardic Inspiration uses on a short or long rest (previously only on a long rest).",
          "level": 5,
          "name": "Font of Inspiration",
          "source": "class",
        },
        {
          "description": "As an action, start a performance that lasts until the end of your next turn. During that time, friendly creatures within 30 ft have advantage on saves against being frightened or charmed.",
          "level": 6,
          "name": "Countercharm",
          "source": "class",
        },
        {
          "description": "You can attack twice whenever you take the Attack action.",
          "level": 6,
          "name": "Extra Attack",
          "source": "subclass",
        },
        {
          "description": "Choose two spells from any class (including this one). They count as bard spells for you. Two more at level 14, two more at level 18.",
          "level": 10,
          "name": "Magical Secrets",
          "source": "class",
        },
      ],
      "resources": [
        {
          "description": "Bonus action: grant one creature within 60 ft a Bardic Inspiration d10. They add it to one roll within 10 minutes. Regain all uses on a short or long rest.",
          "die": "d10",
          "key": "bardicInspiration",
          "label": "Bardic Inspiration",
          "recharge": "short-or-long",
          "total": 2,
        },
      ],
    },
    "level": 11,
  },
