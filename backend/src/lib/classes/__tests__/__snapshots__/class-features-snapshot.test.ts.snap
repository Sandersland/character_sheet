  {
    "info": {
      "features": [
        {
          "description": "Choose two of your skill proficiencies (or one skill + Thieves' Tools). Your proficiency bonus is doubled for those skills. Two more at level 6.",
          "level": 1,
          "name": "Expertise",
          "source": "class",
        },
        {
          "description": "Once per turn, deal extra damage to a target you hit with a finesse or ranged weapon when you have advantage on the attack or an ally is adjacent to the target. 1d6 at L1, +1d6 every odd level (10d6 at L19).",
          "level": 1,
          "name": "Sneak Attack",
          "source": "class",
        },
        {
          "description": "Secret mix of dialect and codewords used by thieves' guilds. Takes 4× as long to convey a message compared to open speech. Also understand signs and symbols used by criminals.",
          "level": 1,
          "name": "Thieves' Cant",
          "source": "class",
        },
        {
          "description": "As a bonus action, take the Dash, Disengage, or Hide action.",
          "level": 2,
          "name": "Cunning Action",
          "source": "class",
        },
        {
          "description": "You have advantage on attack rolls against any creature that hasn't taken a turn yet this combat. Any hit against a surprised creature is a critical hit.",
          "level": 3,
          "name": "Assassinate",
          "source": "subclass",
        },
        {
          "description": "You gain proficiency with the disguise kit and the poisoner's kit.",
          "level": 3,
          "name": "Bonus Proficiencies",
          "source": "subclass",
        },
        {
          "description": "When an attacker you can see hits you, use your reaction to halve the attack's damage.",
          "level": 5,
          "name": "Uncanny Dodge",
          "source": "class",
