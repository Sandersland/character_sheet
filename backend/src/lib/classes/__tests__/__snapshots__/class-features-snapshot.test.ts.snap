          "description": "As an action, transform into a beast you have seen. Max CR: 1/4 at L2 (no flying or swimming speed); 1/2 at L4 (no flying speed); 1 at L8. You retain your mental stats and class features but use the beast's physical stats. Lasts up to half your druid level in hours (minimum 1). Reverts when reduced to 0 HP.",
          "level": 2,
          "name": "Wild Shape",
          "source": "class",
        },
        {
          "description": "You gain access to additional spells based on your chosen terrain (arctic, coast, desert, forest, grassland, mountain, swamp, or Underdark). These spells are always prepared for you and don't count against your prepared spells.",
          "level": 3,
          "name": "Circle Spells",
          "source": "subclass",
        },
        {
          "description": "Moving through nonmagical difficult terrain costs no extra movement, and you can pass through nonmagical plants without being slowed. Advantage on saves against magically created or manipulated plants.",
          "level": 6,
          "name": "Land's Stride",
          "source": "subclass",
        },
        {
          "description": "Immune to poison and disease. Elementals and fey can't charm or frighten you.",
          "level": 10,
          "name": "Nature's Ward",
          "source": "subclass",
        },
        {
          "description": "When a beast or plant attacks you, it must make a Wisdom saving throw (DC 8 + proficiency + Wisdom modifier) or choose a different target. On a success, it is immune to this feature for 24 hours.",
          "level": 14,
          "name": "Nature's Sanctuary",
          "source": "subclass",
        },
        {
          "description": "You can cast many druid spells in any shape you assume using Wild Shape. You can perform the somatic and verbal components of a druid spell while in beast form.",
          "level": 18,
          "name": "Beast Spells",
          "source": "class",
        },
        {
          "description": "The primal magic you wield causes you to age more slowly. For every 10 years that pass, your body ages only 1 year.",
          "level": 18,
          "name": "Timeless Body",
          "source": "class",
        },
      ],
      "resources": [
        {
          "description": "Transform into a beast (max CR 1). Lasts up to 9 hour(s). Regain all uses on a short or long rest.",
          "key": "wildShape",
          "label": "Wild Shape",
          "recharge": "short-or-long",
          "total": 2,
        },
      ],
    },
    "level": 18,
  },
