        },
        {
          "description": "Bond with a beast companion of CR 1/4 or lower. It acts on your turn (using your action to command it after the first round). It uses your proficiency bonus and gains bonus HP equal to four times your ranger level.",
          "level": 3,
          "name": "Ranger's Companion",
