exports[`deriveResourcesForCharacterRow > derives level + resources from XP and the primary class entry 1`] = `
{
  "features": [
    {
      "description": "Choose a fighting style specialty: Archery (+2 ranged attack rolls), Defense (+1 AC in armor), Dueling (+2 melee damage when only wielding one weapon), Great Weapon Fighting (reroll 1s and 2s on damage with two-handed weapons), Protection (impose disadvantage on attacks against adjacent allies), or Two-Weapon Fighting (add ability modifier to off-hand damage).",
      "level": 1,
      "name": "Fighting Style",
      "source": "class",
    },
    {
      "description": "As a bonus action, regain 1d10 + your fighter level HP. Regain use on a short or long rest.",
      "level": 1,
      "name": "Second Wind",
      "source": "class",
    },
    {
      "description": "Take one additional action on your turn. Regain use(s) on a short or long rest. You have 2 uses starting at level 17.",
      "level": 2,
      "name": "Action Surge",
      "source": "class",
    },
    {
      "description": "You learn maneuvers fueled by superiority dice (d8s). You have 4 dice and regain all expended dice on a short or long rest. Maneuvers can only be used once per attack unless otherwise stated.",
      "level": 3,
      "name": "Combat Superiority",
      "source": "subclass",
    },
    {
      "description": "You gain proficiency with one type of artisan's tools of your choice.",
      "level": 3,
      "name": "Student of War",
      "source": "subclass",
    },
    {
      "description": "You can attack twice when taking the Attack action. Three times at level 11; four times at level 20.",
      "level": 5,
      "name": "Extra Attack",
      "source": "class",
    },
    {
      "description": "If you spend at least 1 minute observing or interacting with another creature outside combat, you can compare two of its ability scores, armor class, hit points, hit dice, or levels to your own.",
      "level": 7,
      "name": "Know Your Enemy",
      "source": "subclass",
    },
    {
      "description": "Reroll a failed saving throw (you must use the new roll). Regain use(s) on a long rest. Two uses at level 13, three at level 17.",
      "level": 9,
      "name": "Indomitable",
      "source": "class",
    },
    {
      "description": "Your superiority dice turn into d10s.",
      "level": 10,
      "name": "Improved Combat Superiority (d10)",
      "source": "subclass",
    },
    {
      "description": "When you roll initiative and have no superiority dice remaining, you regain 1 superiority die.",
      "level": 15,
      "name": "Relentless",
      "source": "subclass",
    },
    {
      "description": "Your superiority dice turn into d12s.",
      "level": 18,
      "name": "Improved Combat Superiority (d12)",
      "source": "subclass",
    },
  ],
  "maneuverChoiceCount": 9,
  "maneuverSaveDC": 17,
  "resources": [
    {
      "description": "Bonus action: regain 1d10 + 20 HP. Regain use on a short or long rest.",
      "key": "secondWind",
      "label": "Second Wind",
      "recharge": "shortRest",
      "total": 1,
    },
    {
      "description": "Take one additional action on your turn. Regain use(s) on a short or long rest.",
      "key": "actionSurge",
      "label": "Action Surge",
      "recharge": "shortRest",
      "total": 2,
    },
    {
      "description": "Reroll a failed saving throw (must accept the new result). Regain use(s) on a long rest.",
      "key": "indomitable",
      "label": "Indomitable",
      "recharge": "longRest",
      "total": 3,
    },
    {
      "description": "Spend to fuel maneuvers. Maneuver save DC 17. Regain all on a short or long rest.",
      "die": "d12",
      "key": "superiorityDice",
      "label": "Superiority Dice",
      "recharge": "short-or-long",
      "total": 6,
