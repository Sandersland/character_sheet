          "total": 70,
        },
        {
          "description": "Channel divine energy for oath-specific effects. Regain use on a short or long rest.",
          "key": "channelDivinity",
          "label": "Channel Divinity",
          "recharge": "short-or-long",
          "total": 1,
        },
      ],
    },
    "level": 14,
  },
  {
    "info": {
      "features": [
        {
          "description": "As an action, sense the presence of celestials, fiends, and undead within 60 ft until the end of your next turn (they aren't hidden from this sense). You can also detect consecrated or desecrated places/objects. Uses = 1 + Charisma modifier per long rest.",
          "level": 1,
          "name": "Divine Sense",
          "source": "class",
        },
        {
          "description": "Touch to restore HP from a pool of 5 × your paladin level. Alternatively, spend 5 HP from the pool to cure one disease or neutralize one poison. The pool replenishes on a long rest.",
          "level": 1,
          "name": "Lay on Hands",
          "source": "class",
        },
        {
          "description": "When you hit with a melee weapon attack, expend one spell slot to deal +2d8 radiant damage (+1d8 per slot level above 1st, max +5d8). Undead and fiends take an additional 1d8 radiant damage.",
          "level": 2,
          "name": "Divine Smite",
          "source": "class",
        },
        {
          "description": "Choose a fighting style specialty: Defense (+1 AC in armor), Dueling (+2 melee damage with one weapon), Great Weapon Fighting (reroll 1s and 2s on damage), or Protection (impose disadvantage on attacks against adjacent allies).",
          "level": 2,
          "name": "Fighting Style",
          "source": "class",
        },
        {
          "description": "You cast spells using Charisma starting at level 2. Half-caster progression (you gain spell slots more slowly than full casters). You prepare a number of paladin spells equal to your Charisma modifier + half your paladin level (rounded down).",
          "level": 2,
          "name": "Spellcasting",
          "source": "class",
        },
        {
          "description": "You can channel divine energy through your sacred oath to fuel magical effects. You have 1 use, regained on a short or long rest. The specific options depend on your oath (see subclass features).",
          "level": 3,
          "name": "Channel Divinity",
          "source": "class",
        },
        {
          "description": "As an action, restrain a creature within 10 ft: ethereal vines bind it until it makes a Strength or Dexterity save (DC = paladin spell save DC). Uses the Channel Divinity pool.",
          "level": 3,
          "name": "Channel Divinity: Nature's Wrath",
          "source": "subclass",
        },
        {
          "description": "As an action, present your holy symbol. Each fey or fiend within 30 ft must make a Wisdom saving throw or be turned for 1 minute. A turned creature that has nowhere to flee cowers. Uses the Channel Divinity pool.",
          "level": 3,
          "name": "Channel Divinity: Turn the Faithless",
          "source": "subclass",
        },
        {
          "description": "The divine magic flowing through you makes you immune to disease.",
          "level": 3,
          "name": "Divine Health",
          "source": "class",
        },
        {
          "description": "Always-prepared oath spells: Ensnaring Strike, Speak with Animals (L3); Moonbeam, Misty Step (L5); Plant Growth, Protection from Energy (L9); Ice Storm, Stoneskin (L13); Commune with Nature, Tree Stride (L17).",
          "level": 3,
          "name": "Oath Spells",
          "source": "subclass",
        },
        {
          "description": "You can attack twice whenever you take the Attack action on your turn.",
          "level": 5,
          "name": "Extra Attack",
          "source": "class",
        },
        {
          "description": "Friendly creatures within 10 ft add your Charisma modifier (minimum +1) to saving throws while you are conscious. Aura extends to 30 ft at level 18.",
          "level": 6,
          "name": "Aura of Protection",
          "source": "class",
        },
        {
          "description": "You and friendly creatures within 10 ft have resistance to damage from spells (30 ft at level 18).",
          "level": 7,
          "name": "Aura of Warding",
          "source": "subclass",
        },
        {
          "description": "Friendly creatures within 10 ft can't be frightened while you are conscious. Aura extends to 30 ft at level 18.",
          "level": 10,
          "name": "Aura of Courage",
          "source": "class",
        },
        {
          "description": "Whenever you hit with a melee weapon, you deal an extra 1d8 radiant damage in addition to any other Divine Smite dice.",
          "level": 11,
          "name": "Improved Divine Smite",
          "source": "class",
        },
        {
          "description": "As an action, end one spell on yourself or one willing creature within reach. Uses = Charisma modifier per long rest (minimum 1).",
          "level": 14,
          "name": "Cleansing Touch",
          "source": "class",
        },
        {
          "description": "When reduced to 0 HP without dying outright, you drop to 1 HP instead. Once used, regain on a long rest. You also don't suffer the aging effects of spells or magical effects.",
          "level": 15,
          "name": "Undying Sentinel",
          "source": "subclass",
        },
      ],
      "resources": [
        {
          "description": "Action: sense celestials, fiends, and undead within 60 ft until end of next turn. Regain all uses on a long rest.",
          "key": "divineSense",
          "label": "Divine Sense",
          "recharge": "longRest",
          "total": 3,
        },
        {
          "description": "Pool of 75 healing HP. Touch to restore HP; spend 5 HP to cure a disease or neutralize a poison. Replenishes on a long rest.",
          "key": "layOnHands",
          "label": "Lay on Hands",
          "recharge": "longRest",
          "total": 75,
        },
        {
          "description": "Channel divine energy for oath-specific effects. Regain use on a short or long rest.",
          "key": "channelDivinity",
          "label": "Channel Divinity",
          "recharge": "short-or-long",
          "total": 1,
        },
      ],
    },
    "level": 15,
  },
