          "name": "Evasion",
          "source": "class",
        },
        {
          "description": "Spend 7 days and 25 gp creating a false identity, including documentation, established acquaintances, and disguises. You can't adopt an identity that belongs to someone else.",
          "level": 9,
          "name": "Infiltration Expertise",
          "source": "subclass",
        },
        {
          "description": "When making an ability check with a skill or tool you're proficient in, treat a d20 roll of 9 or lower as a 10.",
          "level": 11,
          "name": "Reliable Talent",
          "source": "class",
        },
        {
          "description": "After studying a creature for 3 hours, you can mimic its speech, writing, and behavior. A Wisdom (Insight) check contested by your Charisma (Deception) reveals the imposture.",
          "level": 13,
          "name": "Impostor",
          "source": "subclass",
        },
        {
          "description": "If able to hear, you are aware of the location of any hidden or invisible creature within 10 feet.",
          "level": 14,
          "name": "Blindsense",
          "source": "class",
        },
        {
          "description": "You gain proficiency in Wisdom saving throws.",
          "level": 15,
          "name": "Slippery Mind",
          "source": "class",
        },
        {
          "description": "When you hit a surprised creature, it must make a Constitution save (DC 8 + your Dexterity modifier + proficiency bonus) or take double damage from the attack.",
          "level": 17,
          "name": "Death Strike",
          "source": "subclass",
        },
      ],
      "resources": [],
    },
    "level": 17,
  },
