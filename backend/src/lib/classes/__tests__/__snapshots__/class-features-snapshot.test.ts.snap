          "description": "Once per turn, deal extra damage to a target you hit with a finesse or ranged weapon when you have advantage on the attack or an ally is adjacent to the target. 1d6 at L1, +1d6 every odd level (10d6 at L19).",
          "level": 1,
          "name": "Sneak Attack",
          "source": "class",
        },
        {
          "description": "Secret mix of dialect and codewords used by thieves' guilds. Takes 4× as long to convey a message compared to open speech. Also understand signs and symbols used by criminals.",
          "level": 1,
          "name": "Thieves' Cant",
          "source": "class",
        },
        {
          "description": "As a bonus action, take the Dash, Disengage, or Hide action.",
          "level": 2,
          "name": "Cunning Action",
          "source": "class",
        },
        {
          "description": "Use the Cunning Action bonus action to make a Sleight of Hand check, use Thieves' Tools to disarm a trap or open a lock, or take the Use an Object action.",
          "level": 3,
          "name": "Fast Hands",
          "source": "subclass",
        },
        {
          "description": "Climbing no longer costs extra movement. When you make a running jump, the distance you cover increases by a number of feet equal to your Dexterity modifier.",
          "level": 3,
          "name": "Second-Story Work",
          "source": "subclass",
        },
        {
          "description": "When an attacker you can see hits you, use your reaction to halve the attack's damage.",
          "level": 5,
          "name": "Uncanny Dodge",
          "source": "class",
        },
        {
          "description": "When subjected to an effect that allows a Dexterity save for half damage, you take no damage on a success and half damage on a failure.",
          "level": 7,
          "name": "Evasion",
          "source": "class",
        },
        {
          "description": "You have advantage on a Dexterity (Stealth) check if you move no more than half your speed on the same turn.",
          "level": 9,
          "name": "Supreme Sneak",
          "source": "subclass",
        },
        {
          "description": "When making an ability check with a skill or tool you're proficient in, treat a d20 roll of 9 or lower as a 10.",
          "level": 11,
          "name": "Reliable Talent",
          "source": "class",
        },
        {
          "description": "You ignore all class, race, and level requirements on the use of magic items.",
          "level": 13,
          "name": "Use Magic Device",
          "source": "subclass",
        },
        {
          "description": "If able to hear, you are aware of the location of any hidden or invisible creature within 10 feet.",
          "level": 14,
          "name": "Blindsense",
          "source": "class",
        },
        {
          "description": "You gain proficiency in Wisdom saving throws.",
          "level": 15,
          "name": "Slippery Mind",
          "source": "class",
        },
        {
          "description": "You take two turns during the first round of any combat: your first turn at your normal initiative and your second at your initiative minus 10. You can't use this feature when surprised.",
          "level": 17,
          "name": "Thief's Reflexes",
          "source": "subclass",
        },
        {
          "description": "No attack roll has advantage against you while you aren't incapacitated.",
          "level": 18,
          "name": "Elusive",
          "source": "class",
        },
      ],
      "resources": [],
    },
    "level": 18,
  },
