          "source": "class",
        },
        {
          "description": "Choose a fighting style specialty: Defense (+1 AC in armor), Dueling (+2 melee damage with one weapon), Great Weapon Fighting (reroll 1s and 2s on damage), or Protection (impose disadvantage on attacks against adjacent allies).",
          "level": 2,
          "name": "Fighting Style",
          "source": "class",
        },
        {
          "description": "You cast spells using Charisma starting at level 2. Half-caster progression (you gain spell slots more slowly than full casters). You prepare a number of paladin spells equal to your Charisma modifier + half your paladin level (rounded down).",
          "level": 2,
          "name": "Spellcasting",
          "source": "class",
        },
        {
          "description": "You can channel divine energy through your sacred oath to fuel magical effects. You have 1 use, regained on a short or long rest. The specific options depend on your oath (see subclass features).",
          "level": 3,
          "name": "Channel Divinity",
          "source": "class",
        },
        {
          "description": "The divine magic flowing through you makes you immune to disease.",
          "level": 3,
          "name": "Divine Health",
          "source": "class",
        },
        {
          "description": "You can attack twice whenever you take the Attack action on your turn.",
          "level": 5,
          "name": "Extra Attack",
          "source": "class",
        },
        {
          "description": "Friendly creatures within 10 ft add your Charisma modifier (minimum +1) to saving throws while you are conscious. Aura extends to 30 ft at level 18.",
          "level": 6,
          "name": "Aura of Protection",
          "source": "class",
        },
        {
          "description": "Friendly creatures within 10 ft can't be frightened while you are conscious. Aura extends to 30 ft at level 18.",
          "level": 10,
          "name": "Aura of Courage",
          "source": "class",
        },
        {
          "description": "Whenever you hit with a melee weapon, you deal an extra 1d8 radiant damage in addition to any other Divine Smite dice.",
          "level": 11,
          "name": "Improved Divine Smite",
          "source": "class",
        },
      ],
      "resources": [
        {
          "description": "Action: sense celestials, fiends, and undead within 60 ft until end of next turn. Regain all uses on a long rest.",
          "key": "divineSense",
          "label": "Divine Sense",
          "recharge": "longRest",
          "total": 3,
        },
        {
          "description": "Pool of 65 healing HP. Touch to restore HP; spend 5 HP to cure a disease or neutralize a poison. Replenishes on a long rest.",
          "key": "layOnHands",
          "label": "Lay on Hands",
          "recharge": "longRest",
          "total": 65,
        },
        {
          "description": "Channel divine energy for oath-specific effects. Regain use on a short or long rest.",
          "key": "channelDivinity",
          "label": "Channel Divinity",
          "recharge": "short-or-long",
          "total": 1,
        },
      ],
    },
    "level": 13,
  },
