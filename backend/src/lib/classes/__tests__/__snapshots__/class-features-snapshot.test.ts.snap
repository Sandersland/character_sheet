          "description": "When you use your action to cast a cantrip, you can make one weapon attack as a bonus action.",
          "level": 7,
          "name": "War Magic",
          "source": "subclass",
        },
        {
          "description": "Reroll a failed saving throw (you must use the new roll). Regain use(s) on a long rest. Two uses at level 13, three at level 17.",
          "level": 9,
          "name": "Indomitable",
          "source": "class",
        },
        {
          "description": "When you hit a creature with a weapon attack, that creature has disadvantage on the next saving throw it makes against a spell you cast before the end of your next turn.",
          "level": 10,
          "name": "Eldritch Strike",
          "source": "subclass",
        },
        {
          "description": "When you use your Action Surge, you can teleport up to 30 feet to an unoccupied space you can see, before or after the additional action.",
          "level": 15,
          "name": "Arcane Charge",
          "source": "subclass",
        },
        {
          "description": "When you use your action to cast a spell, you can make one weapon attack as a bonus action.",
          "level": 18,
          "name": "Improved War Magic",
          "source": "subclass",
        },
      ],
      "resources": [
        {
          "description": "Bonus action: regain 1d10 + 20 HP. Regain use on a short or long rest.",
          "key": "secondWind",
          "label": "Second Wind",
          "recharge": "shortRest",
          "total": 1,
        },
        {
          "description": "Take one additional action on your turn. Regain use(s) on a short or long rest.",
          "key": "actionSurge",
          "label": "Action Surge",
          "recharge": "shortRest",
          "total": 2,
        },
        {
          "description": "Reroll a failed saving throw (must accept the new result). Regain use(s) on a long rest.",
          "key": "indomitable",
          "label": "Indomitable",
          "recharge": "longRest",
          "total": 3,
        },
      ],
    },
    "level": 20,
  },
]
