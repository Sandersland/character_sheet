        {
          "description": "Your patron grants a boon: Pact of the Chain (familiar with special forms), Pact of the Blade (summon a pact weapon), or Pact of the Tome (Book of Shadows with extra cantrips and rituals).",
          "level": 3,
          "name": "Pact Boon",
          "source": "class",
        },
        {
          "description": "Add a d10 to one ability check or saving throw you make. Once used, regain on a short or long rest.",
          "level": 6,
          "name": "Dark One's Own Luck",
          "source": "subclass",
        },
        {
          "description": "After a short or long rest, choose one damage type. You gain resistance to that type until you choose a different one.",
          "level": 10,
          "name": "Fiendish Resilience",
          "source": "subclass",
        },
        {
          "description": "Choose one 6th-level spell from the warlock list as a Mystic Arcanum. You can cast it once without expending a spell slot per long rest. Gain a 7th-level arcanum at L13, 8th at L15, 9th at L17.",
          "level": 11,
          "name": "Mystic Arcanum",
          "source": "class",
        },
      ],
      "resources": [
