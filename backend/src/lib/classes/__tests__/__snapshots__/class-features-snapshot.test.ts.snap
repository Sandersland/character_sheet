          "description": "Secret mix of dialect and codewords used by thieves' guilds. Takes 4× as long to convey a message compared to open speech. Also understand signs and symbols used by criminals.",
          "level": 1,
          "name": "Thieves' Cant",
          "source": "class",
        },
        {
          "description": "As a bonus action, take the Dash, Disengage, or Hide action.",
          "level": 2,
          "name": "Cunning Action",
          "source": "class",
        },
        {
          "description": "You learn spells from the wizard list (primarily enchantment and illusion), casting with Intelligence. Third-caster progression starting at level 3.",
          "level": 3,
          "name": "Arcane Trickster Spellcasting",
          "source": "subclass",
        },
        {
          "description": "You know the Mage Hand cantrip. The hand is invisible and can pick locks, disarm traps, or steal items using your Sleight of Hand skill — even from creatures as long as you distract them.",
          "level": 3,
          "name": "Mage Hand Legerdemain",
          "source": "subclass",
        },
        {
          "description": "When an attacker you can see hits you, use your reaction to halve the attack's damage.",
          "level": 5,
          "name": "Uncanny Dodge",
          "source": "class",
        },
        {
          "description": "When subjected to an effect that allows a Dexterity save for half damage, you take no damage on a success and half damage on a failure.",
          "level": 7,
          "name": "Evasion",
          "source": "class",
        },
      ],
      "resources": [],
    },
