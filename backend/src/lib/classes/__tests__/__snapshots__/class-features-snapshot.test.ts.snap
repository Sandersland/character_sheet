          "name": "Divine Intervention",
          "source": "class",
        },
        {
          "description": "When you use Invoke Duplicity, you can create up to four duplicates instead of one. As a bonus action on your turn, move any number of them up to 30 ft (no more than 120 ft away from you).",
          "level": 17,
          "name": "Improved Duplicity",
          "source": "subclass",
        },
      ],
      "resources": [
        {
          "description": "Channel divine energy for special effects (Turn Undead DC 15, plus domain options). Regain all uses on a short or long rest.",
          "key": "channelDivinity",
          "label": "Channel Divinity",
          "recharge": "short-or-long",
          "total": 2,
        },
      ],
    },
    "level": 17,
  },
  {
    "info": {
      "features": [
