  {
    "info": {
      "features": [
        {
          "description": "You gain proficiency with heavy armor.",
          "level": 1,
          "name": "Bonus Proficiency",
          "source": "subclass",
        },
        {
          "description": "Whenever you use a spell of 1st level or higher to restore hit points to a creature, the creature regains additional HP equal to 2 + the spell's level.",
          "level": 1,
          "name": "Disciple of Life",
          "source": "subclass",
        },
        {
          "description": "Always-prepared domain spells (they don't count against your prepared total): Bless, Cure Wounds (L3); Lesser Restoration, Spiritual Weapon (L3); Beacon of Hope, Revivify (L5); Death Ward, Guardian of Faith (L7); Mass Cure Wounds, Raise Dead (L9).",
          "level": 1,
          "name": "Domain Spells",
          "source": "subclass",
        },
        {
          "description": "You cast spells using Wisdom. Full-caster progression. You prepare a number of cleric spells equal to your Wisdom modifier + your cleric level (minimum 1).",
          "level": 1,
          "name": "Spellcasting",
          "source": "class",
        },
        {
          "description": "As an action, evoke healing energy that restores a total of 5× your cleric level HP, divided among creatures within 30 ft (up to half their maximum HP each). Uses the Channel Divinity pool.",
          "level": 2,
          "name": "Channel Divinity: Preserve Life",
          "source": "subclass",
        },
        {
          "description": "As an action, each undead within 30 ft that can see or hear you must make a Wisdom save (DC 8 + proficiency + Wisdom modifier) or be turned for 1 minute. Turned undead flee you.",
          "level": 2,
          "name": "Channel Divinity: Turn Undead",
          "source": "class",
        },
        {
          "description": "When you turn an undead, any with CR 1/2 or lower are instantly destroyed (CR 1 at L8; CR 2 at L11; CR 3 at L14; CR 4 at L17).",
          "level": 5,
          "name": "Destroy Undead",
          "source": "class",
        },
        {
          "description": "When you cast a healing spell of 1st level or higher that restores HP to another creature, you regain HP equal to 2 + the spell's level.",
          "level": 6,
          "name": "Blessed Healer",
          "source": "subclass",
        },
        {
          "description": "Once per turn when you hit with a weapon, deal an extra 1d8 radiant damage (+2d8 at level 14).",
          "level": 8,
          "name": "Divine Strike",
          "source": "subclass",
        },
        {
          "description": "Call on your deity for aid. Roll percentile dice — on a result ≤ your cleric level, your deity intervenes. On a success, you can't use this feature again for 7 days. At level 20 it automatically succeeds.",
          "level": 10,
          "name": "Divine Intervention",
          "source": "class",
