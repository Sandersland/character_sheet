      "features": [
        {
          "description": "Choose two of your skill proficiencies (or one skill + Thieves' Tools). Your proficiency bonus is doubled for those skills. Two more at level 6.",
          "level": 1,
          "name": "Expertise",
          "source": "class",
        },
        {
          "description": "Once per turn, deal extra damage to a target you hit with a finesse or ranged weapon when you have advantage on the attack or an ally is adjacent to the target. 1d6 at L1, +1d6 every odd level (10d6 at L19).",
          "level": 1,
          "name": "Sneak Attack",
          "source": "class",
        },
        {
          "description": "Secret mix of dialect and codewords used by thieves' guilds. Takes 4× as long to convey a message compared to open speech. Also understand signs and symbols used by criminals.",
          "level": 1,
          "name": "Thieves' Cant",
          "source": "class",
        },
        {
          "description": "As a bonus action, take the Dash, Disengage, or Hide action.",
          "level": 2,
          "name": "Cunning Action",
          "source": "class",
        },
        {
          "description": "You learn spells from the wizard list (primarily enchantment and illusion), casting with Intelligence. Third-caster progression starting at level 3.",
          "level": 3,
          "name": "Arcane Trickster Spellcasting",
          "source": "subclass",
        },
        {
          "description": "You know the Mage Hand cantrip. The hand is invisible and can pick locks, disarm traps, or steal items using your Sleight of Hand skill — even from creatures as long as you distract them.",
          "level": 3,
          "name": "Mage Hand Legerdemain",
          "source": "subclass",
        },
        {
          "description": "When an attacker you can see hits you, use your reaction to halve the attack's damage.",
          "level": 5,
          "name": "Uncanny Dodge",
          "source": "class",
        },
        {
          "description": "When subjected to an effect that allows a Dexterity save for half damage, you take no damage on a success and half damage on a failure.",
          "level": 7,
          "name": "Evasion",
          "source": "class",
        },
        {
          "description": "If you are hidden when you cast a spell, the target has disadvantage on any saving throw it makes against the spell on the same turn.",
          "level": 9,
          "name": "Magical Ambush",
          "source": "subclass",
        },
        {
          "description": "When making an ability check with a skill or tool you're proficient in, treat a d20 roll of 9 or lower as a 10.",
          "level": 11,
          "name": "Reliable Talent",
          "source": "class",
        },
        {
          "description": "As a bonus action, direct your Mage Hand to distract a creature within 5 ft of it. Gain advantage on the next attack roll against that creature before the end of your turn.",
          "level": 13,
          "name": "Versatile Trickster",
          "source": "subclass",
        },
        {
          "description": "If able to hear, you are aware of the location of any hidden or invisible creature within 10 feet.",
          "level": 14,
          "name": "Blindsense",
          "source": "class",
        },
        {
          "description": "You gain proficiency in Wisdom saving throws.",
          "level": 15,
          "name": "Slippery Mind",
          "source": "class",
        },
        {
          "description": "Immediately after a creature casts a spell that targets you, use your reaction to force it to make a saving throw with its spellcasting ability modifier (DC = your spell save DC). On failure, you negate the spell and steal it — you can cast it (same level) once without a slot within 8 hours. Once used, regain on a long rest.",
          "level": 17,
          "name": "Spell Thief",
          "source": "subclass",
        },
      ],
      "resources": [],
    },
    "level": 17,
  },
