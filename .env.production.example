# Copy to .env.production and fill in. Used by docker-compose.prod.yml.
# On Railway, set these as service variables instead of using this file.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=character_sheet
POSTGRES_PASSWORD=change-me
POSTGRES_DB=character_sheet

# Backend reads DATABASE_URL directly. In docker-compose.prod.yml it is composed
# from the POSTGRES_* vars above and points at the `db` service. On Railway,
# reference the Postgres plugin's connection string instead.
# DATABASE_URL=postgresql://character_sheet:change-me@db:5432/character_sheet

# ── App ───────────────────────────────────────────────────────────────────────
# Host port to expose the combined single-origin app on.
APP_PORT=4000

# Port the server listens on inside the container (Railway injects its own PORT).
PORT=4000

# Path to the built SPA the API serves (single-origin mode). The combined image
# sets this to /app/public already; leave as-is for docker-compose.prod.yml.
SERVE_STATIC_DIR=/app/public

# ── CORS (split mode only) ────────────────────────────────────────────────────
# Leave EMPTY for single-origin (same host serves SPA + API → no CORS).
# For split deploys, set a comma-separated allowlist of frontend origins:
# CORS_ORIGIN=https://dev.example.com,https://example.com
CORS_ORIGIN=

# ── Frontend build (split mode only) ──────────────────────────────────────────
# Baked into the SPA at build time by frontend/Dockerfile.prod. Single-origin
# uses "/api" (the default in the combined image); split uses the API's URL:
# VITE_API_URL=https://api-dev.example.com/api
VITE_API_URL=/api
