BACKEND_PORT=4000
FRONTEND_PORT=5173
# Dev runs single-origin via the Vite proxy: the SPA serves /api and forwards it
# to the backend (see docker-compose.yml frontend.VITE_PROXY_TARGET). Leave as
# /api unless you intentionally point the SPA at an absolute API origin.
VITE_API_URL=/api

# ── Google OAuth (optional; sign-in is disabled until both are set) ───────────
# 1. Google Cloud Console → Credentials → OAuth client ID (Web application).
# 2. Configure the consent screen (add yourself as a test user while unpublished).
# 3. Authorized redirect URI: http://localhost:5173/api/auth/google/callback
# APP_BASE_URL is the browser-facing app origin (the SPA, which proxies /api).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_BASE_URL=http://localhost:5173

# Enables POST /api/auth/dev-login (passwordless session for UI verification via
# `npm run seed:verify`). The dev compose already defaults it to true, so leave
# this commented for Docker. Uncomment ONLY to run seed:verify against a backend
# started outside Docker. Hard-disabled when NODE_ENV=production; never enable in
# any real/staging deploy.
# ALLOW_DEV_LOGIN=true

POSTGRES_USER=character_sheet
POSTGRES_PASSWORD=character_sheet
POSTGRES_DB=character_sheet
POSTGRES_PORT=5432
# Used when running the backend outside Docker; inside Compose this is
# overridden with the `db` service hostname (see docker-compose.yml).
DATABASE_URL=postgresql://character_sheet:character_sheet@localhost:5432/character_sheet

PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
